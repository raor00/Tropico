# =============================================================================
# TROPICO WALLET — Variables de entorno
# Copiá este archivo como .env.local y completá los valores reales.
# NUNCA subas .env.local al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Privy — autenticación y embedded wallets
# https://console.privy.io → Settings → App ID
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# -----------------------------------------------------------------------------
# Solana RPC — nodo de conexión a la blockchain
# Se recomienda Helius para mainnet (https://helius.xyz)
# Valores válidos para CLUSTER: mainnet-beta | devnet | testnet
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# -----------------------------------------------------------------------------
# Carlos AI — asistente financiero con IA
# Podés usar Gemini y/o DeepSeek; el backend usa el que esté disponible.
# NEXT_PUBLIC_HAS_* habilita/deshabilita la UI del modelo correspondiente.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
NEXT_PUBLIC_HAS_GEMINI=true
NEXT_PUBLIC_HAS_DEEPSEEK=false

# -----------------------------------------------------------------------------
# Jupiter — agregador de swaps en Solana
# Cuentas de fee ATA (Associated Token Account) para cobro de comisiones.
# Estas son direcciones de Solana (base58), no claves secretas.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TROPICO_FEE_ATA_SOL=your-fee-ata-sol-address
NEXT_PUBLIC_TROPICO_FEE_ATA_USDC=your-fee-ata-usdc-address
NEXT_PUBLIC_TROPICO_FEE_ATA_USDT=your-fee-ata-usdt-address

# -----------------------------------------------------------------------------
# Tropico Pay / Integraciones — API de pagos merchant
# MERCHANT_WALLET: direccion Solana del merchant de prueba
# TROPICO_API_KEY / TROPICO_PAY_API_KEY: claves del servicio de cobros
# -----------------------------------------------------------------------------
MERCHANT_WALLET=your-merchant-wallet-address
TROPICO_API_KEY=your-tropico-api-key-here
TROPICO_PAY_API_KEY=your-tropico-pay-api-key-here

# -----------------------------------------------------------------------------
# App config — configuracion general
# NEXT_PUBLIC_BASE_URL: URL publica del deployment (sin barra final)
# Ejemplo: https://tropico.app o http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
